<Window
    x:Name="RootWindow"
    x:Class="DraggableMap.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DraggableMap"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid Background="Transparent">
            <Canvas
                x:Name="TileCanvas"
                Background="#F2F0E7"
                SnapsToDevicePixels="True">
                <Canvas.Style>
                    <Style TargetType="Canvas">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="IsHitTestVisible" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTiles, ElementName=RootWindow}" Value="False">
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Canvas.Style>
            </Canvas>
        </Grid>

        <ItemsControl
            x:Name="OverlaysItemsControl"
            Visibility="{Binding ShowGeoJson, ElementName=RootWindow, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsManipulationEnabled="False" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Path
                        Data="{Binding Geometry}"
                        Fill="{Binding Fill}"
                        Stroke="{Binding Stroke}"
                        StrokeThickness="{Binding StrokeThickness}"
                        StrokeLineJoin="Round"
                        ToolTip="{Binding Name}"
                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl
            x:Name="PinsItemsControl"
            Visibility="{Binding ShowPins, ElementName=RootWindow, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate x:Name="ElementCanvase">
                    <Canvas IsManipulationEnabled="False" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:MapPinFull
                        Width="40"
                        Height="40"
                        Fill="Blue"
                        Stroke="White"
                        ToolTip="{Binding Name}"
                        ToolTipService.Placement="Top">
                        <local:MapPinFull.RenderTransform>
                            <MatrixTransform Matrix="{Binding Transformation}" />
                        </local:MapPinFull.RenderTransform>
                    </local:MapPinFull>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="{x:Type ContentPresenter}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Panel.ZIndex" Value="9" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>

        <Border
            x:Name="DisplayPanel"
            Margin="8"
            Padding="8"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#F3FFFFFF"
            BorderBrush="#55000000"
            BorderThickness="1"
            CornerRadius="6"
            Panel.ZIndex="20">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Display" />
                <CheckBox Content="Tiles" IsChecked="{Binding ShowTiles, ElementName=RootWindow}" />
                <CheckBox Content="Pins" IsChecked="{Binding ShowPins, ElementName=RootWindow}" />
                <CheckBox Content="GeoJson" IsChecked="{Binding ShowGeoJson, ElementName=RootWindow}" />
                <ItemsControl
                    x:Name="OverlayFiltersItemsControl"
                    Margin="12,4,0,0"
                    Visibility="{Binding ShowGeoJson, ElementName=RootWindow, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsVisible}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <UniformGrid
            Margin="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Columns="1">
            <Button
                Width="60"
                Height="60"
                Margin="4"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="HandleZoomIn">
                <Canvas Width="20" Height="20">
                    <Path
                        Data="M0,10 H20 M10,0 v20"
                        Stroke="Black"
                        StrokeThickness="4" />
                </Canvas>
            </Button>
            <Button
                Width="60"
                Height="60"
                Margin="4"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="HandleZoomOut">
                <Canvas Width="20" Height="20">
                    <Path
                        Data="M0,10 H20"
                        Stroke="Black"
                        StrokeThickness="4" />
                </Canvas>
            </Button>
        </UniformGrid>
    </Grid>
</Window>
